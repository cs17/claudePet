{
  "name": "claude-pet",
  "version": "0.1.0",
  "description": "Evolving pixel-art pet companion for Claude Code",
  "type": "module",
  "main": "dist/server.js",
  "scripts": {
    "generate": "python3 scripts/generate-data.py",
    "build": "tsc && rm -rf dist/data && cp -r src/data dist/data",
    "start": "node dist/server.js",
    "dev": "tsc --watch",
    "test": "node --experimental-vm-modules node_modules/.bin/jest"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.12.0",
    "zod": "^3.23.0"
  },
  "devDependencies": {
    "@types/jest": "^29.5.0",
    "@types/node": "^22.0.0",
    "jest": "^29.7.0",
    "ts-jest": "^29.3.0",
    "typescript": "^5.7.0"
  }
}
